# Lotus — environment template. Copy to .env and fill in.
# NEVER commit a real .env (it is gitignored).

# --- PostgreSQL ---
# Async driver URL used by SQLAlchemy/asyncpg.
DATABASE_URL=postgresql+asyncpg://lotus:lotus@127.0.0.1:5432/lotus
# Plain credentials consumed by docker-compose to provision the local DB.
POSTGRES_USER=lotus
POSTGRES_PASSWORD=lotus
POSTGRES_DB=lotus

# --- Interactive Brokers (IB Gateway / TWS) ---
# Ports: Gateway live 4001 / paper 4002; TWS live 7496 / paper 7497.
# This host runs a live-account Gateway on 4001, used for READ-ONLY historical
# data only (no orders, no exec wiring — §15). Point IB_PORT at a paper endpoint
# before wiring anything that could place an order.
IB_HOST=127.0.0.1
IB_PORT=4001
IB_CLIENT_ID=1

# --- nautilus_trader backtest catalog ---
# ParquetDataCatalog root (gitignored). Materialized from IBKR/Postgres.
CATALOG_PATH=./data/catalog

# --- Crypto market data (public REST; no auth needed for market data) ---
# Binance geo-blocks restricted IPs with HTTP 451 (US etc.) — even read-only.
BINANCE_BASE_URL=https://api.binance.com
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz

# --- Domain assumption (§6.2) ---
# Dealer-sign convention is an ASSUMPTION, not an observable. Set it explicitly.
# Supported: long_calls_short_puts (default), short_calls_long_puts
DEALER_SIGN_CONVENTION=long_calls_short_puts
